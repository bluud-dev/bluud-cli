{
  "name": "@bluud/cli",
  "version": "0.1.2",
  "description": "Bluud — agent memory for this project. The npx @bluud/cli CLI installs the Bluud skill into your AI tools and keeps project memory in sync.",
  "type": "module",
  "license": "MIT",
  "author": "Bluud <hello@bluud.dev>",
  "homepage": "https://bluud.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bluud-dev/bluud-cli.git"
  },
  "bugs": {
    "url": "https://github.com/bluud-dev/bluud-cli/issues"
  },
  "bin": {
    "bluud": "bin/cli.mjs"
  },
  "files": [
    "bin",
    "dist",
    "src/skill",
    "src/hooks",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests bin/cli.mjs scripts",
    "lint:fix": "eslint src tests bin/cli.mjs scripts --fix",
    "format:check": "prettier --check src tests bin/cli.mjs scripts",
    "format": "prettier --write src tests bin/cli.mjs scripts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "prepublishOnly": "npm run build",
    "publish:dry-run": "npm run build && npm publish --dry-run"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@vercel/detect-agent": "^1.2.3",
    "picocolors": "^1.0.1",
    "simple-git": "^3.25.0",
    "xdg-basedir": "^5.1.0",
    "yaml": "^2.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "eslint": "^8.57.0",
    "prettier": "^3.3.2",
    "tsup": "^8.1.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^7.16.0",
    "vitest": "^2.0.2"
  }
}
